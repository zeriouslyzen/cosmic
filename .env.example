# Cosmic Deals - Environment Variables
# Copy this file to .env and fill in your actual values. Never commit .env.

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Configuration
# Get these from: https://dashboard.stripe.com/apikeys
# Use pk_live_/sk_live_ in production; pk_test_/sk_test_ for development
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Production site URL (required on Vercel for checkout redirects and CORS)
# Example: https://your-domain.vercel.app
ALLOWED_ORIGIN=https://your-production-domain.com
VITE_SITE_URL=https://your-production-domain.com

# Products are loaded live from Stripe. In the Stripe dashboard, use product metadata for:
#   zodiac   -> e.g. leo or aries,taurus
#   category -> e.g. Just In
#   sku      -> optional inventory sku
#   stock_quantity -> optional number as text
# Images must be public https:// URLs.

# Owner dashboard access (production)
VITE_OWNER_EMAIL=your-owner-email@example.com
OWNER_EMAIL=your-owner-email@example.com

# Local development only — ignored in production builds
VITE_OWNER_DASH_DEV_MODE=false
